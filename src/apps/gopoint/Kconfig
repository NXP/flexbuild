config APP_GOPOINT
	bool "GoPoint demo applications"
	default y
	depends on PLATFORM_IMX
	help
	  Build GoPoint demo applications

if APP_GOPOINT && PLATFORM_IMX

config GP_GTEC_DEMO_FRAMEWORK
	bool "Gtec demo framework"
	default y
	depends on (SOC_IMX8M  && GFX_GPU_VIV) || \
               (SOC_IMX95 && GFX_MALI_IMX)
	help
	  Gtec demo framework for creating graphical demos

