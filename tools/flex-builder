check_board_valid() {
	if [ -z "${MACHINE}" ] || [ "$MACHINE" = "all" ]; then
		echo -e "Error: Please specify the board, for example: bld -m imx8mpevk \n"
		exit 1
	fi
    if [[ " $LS_MACHINE_LIST " =~ " $1 " ]] || [[ " $IMX_MACHINE_LIST " =~ " $1 " ]]; then
        return 0
    else
        echo "Error: Invalid board: '$MACHINE'."
        echo "LS_MACHINE_LIST: $LS_MACHINE_LIST"
        echo "IMX_MACHINE_LIST: $IMX_MACHINE_LIST"
