#!/bin/bash

export FBDIR=$(pwd -P)
export PATH="$FBDIR:$FBDIR/tools:$PATH"


# Color definitions
RED='\e[1;31m'
YELLOW='\e[1;33m'
GREEN='\e[1;32m'
NC='\e[0m'

echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${YELLOW}WARNING: The 'source setup.env' method is deprecated!${NC}"
echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e ""
echo -e "${GREEN}Please use the new Makefile-based build system instead:${NC}"
echo -e ""

make help
