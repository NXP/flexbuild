[ -n "$FBDEBUG" ] && set -xe || set -e
[ -n "$MKDEBUG" ] && SHFLAGS="-ex -o pipefail -c" || SHFLAGS="-c "

source "${FBDIR}/include/console.sh"

generate_linux_itb() {
    # Define paths for initrd and output ITB image
    local initrdimg="$FBOUTDIR/images/rootfs_${DISTRIB_VERSION}_poky_tiny_arm64.cpio.gz"
    local linux_itb="$FBOUTDIR/images/${DISTRIB_VERSION}_poky_tiny_${SOCFAMILY}_arm64.itb"
    local its_template="$FBDIR/configs/linux/linux_${DESTARCH}_${SOCFAMILY}.its"

    # Ensure initrd exists; fetch prebuilt if missing
    [ -f "$initrdimg" ] || get_prebuilt_initrd

    # Create a unique temporary ITS file to prevent race conditions during parallel builds
    local tmpits
    tmpits=$(mktemp --suffix=.its)

    # Prepare the ITS file by replacing placeholders with actual environment paths
    cp -f "$its_template" "$tmpits"
    sed -i "s|../../build|${FBOUTDIR}|g" "$tmpits"
    sed -i "s/rootfs_poky_tiny_${DESTARCH}/rootfs_${DISTRIB_VERSION}_poky_tiny_arm64/" "$tmpits"

    # Generate the FIT image; mkimage will trigger set -e and exit if it fails
    mkimage -f "$tmpits" "$linux_itb" >/dev/null

    rm -f "$tmpits"
    # Display the final image path on success
    fbprint_d "$linux_itb"
}


build_bootscr() {
    CONF_FILE="${FBDIR}/configs/board/${SOCFAMILY}_boot.txt"
    OUT_PATH="${FBOUTDIR}/boot/${SOCFAMILY}_boot.scr"

    if [ ! -f "$CONF_FILE" ]; then
        echo "Error: Configuration file not found at $CONF_FILE"
        exit 1
    fi

    mkdir -p "$(dirname "$OUT_PATH")"

    log_mute mkimage -A arm64 -O linux -T script -C none -a 0 -e 0 -n "boot.scr" -d "$CONF_FILE" "$OUT_PATH"

    if [ $? -eq 0 ]; then
        echo "Success: Created $OUT_PATH"
    else
        echo "Error: mkimage failed"
        exit 1
    fi
}

check_http_request() {
    retcode=$(curl -I -m 10 -o /dev/null -s -w %{http_code} $1) || true
    if [ $retcode != 000 -a ${retcode:0:1} != 2 -a ${retcode:0:1} != 3 ]; then
        fbprint_e "ERROR: HTTP returned $retcode, failed to access $1"
        fbprint_e "Please check your network to ensure $1 is accessable via HTTP from this machine"
        fbprint_e "Please check HTTP proxy settings if it is needed in your environment" && exit 1
    fi
    [ $retcode != 200 -a $retcode != 000 ] && fbprint_e "The requested URL $1 returned error $retcode" && exit 1 || true
}


get_prebuilt_initrd() {
    local tfile=rootfs_${DISTRIB_VERSION}_poky_tiny_arm64.cpio.gz
    if [ ! -f $FBOUTDIR/images/$tfile ]; then
        [ $HOSTARCH = x86_64 ] && check_http_request $initrd_bin_url/$tfile
        rm -f /tmp/$tfile
        log_mute wget --no-check-certificate --tries=3 --timeout=100 --continue --progress=bar --no-verbose --show-progress \
            $DISTRO_SVR_URL/$DISTRIB_VERSION/$tfile -O /tmp/$tfile
        mv /tmp/$tfile $FBOUTDIR/images/$tfile
    fi
}

rfs_umount() {
	for mnt in dev/pts dev sys/kernel/security sys  proc; do
		 if mountpoint -q "$1/$mnt"; then
			 if ! umount "$1/$mnt"; then
				 sleep 2
				 umount -f "$1/$mnt" || true
				 log_mute echo umount $1/$mnt failed
			 else
				 log_mute echo umont $mnt successfully
			 fi
		 else
			 log_mute echo $mnt is not mounted.
		 fi
	done
}

pack_distro_rfs() {
    if [ "$RFS_BASE" = "y" ]; then
        RFSDIR=${FBOUTDIR}/rfs/rootfs_${DISTRIB_VERSION}_debian_base_arm64
    fi
    [ -f $RFSDIR/etc/buildinfo ] || { fbprint_e "$RFSDIR is incomplete"; exit 1; }
    [ $DISTROTYPE = ubuntu -o $DISTROTYPE = debian ] && rfs_umount "$RFSDIR"

    local rname=${RFSDIR##*/}
    local tarname=${rname}_`date +%Y%m%d%H%M`.tar.zst

    fbprint_n "Generating $tarname"
    cd $RFSDIR && tar -C "$RFSDIR" \
          --anchored \
          --exclude='./proc' --exclude='./proc/*' \
          --exclude='./sys'  --exclude='./sys/*'  \
          --exclude='./dev'  --exclude='./dev/*'  \
          --exclude='./run'  --exclude='./run/*'  \
          -cf - . | \
          pzstd -q -o "$FBOUTDIR/images/$tarname"
    cd $FBOUTDIR/images && ln -sf $tarname $FBOUTDIR/images/${rname}.tar.zst && cd $FBDIR
    log_mute ls -lh $FBOUTDIR/images/${rname}*
    fbprint_d $FBOUTDIR/images/$tarname
}


pack_app_components() {
	local appdeb_sym=nxp_apps_debian_${DISTRIB_VERSION}_${MACHINE}_`date +%Y%m%d%H%M`.deb
	local appdeb=nxp_apps_debian_${DISTRIB_VERSION}_${MACHINE}.deb
	local ver="${DISTRIB_VERSION:4}"
	echo packing $appdeb
	cd $FBOUTDIR/images
	fpm -s dir -t deb -n $appdeb -v $ver -a arm64 --deb-no-default-config-files --package $appdeb_sym \
		"${FBOUTDIR}"/apps/apps_${DISTROTYPE}_${MACHINE}/=/ 2>/dev/null
	ln -sf $appdeb_sym $FBOUTDIR/images/$appdeb
	fbprint_d $FBOUTDIR/images/${appdeb_sym}
}


merge_apps() {
    if [ ! -f $RFSDIR/etc/buildinfo ]; then
        echo "No rootfs found, please run 'make rfs' first"
        exit 1
    fi

    if [ $DESTDIR != $RFSDIR ]; then
        for dir in lib bin sbin; do
            [ -d $DESTDIR/$dir ] && cp -Prf --preserve=mode,timestamps $DESTDIR/$dir/* $RFSDIR/$dir/
        done
        ls -d $DESTDIR/* | grep -v -E "lib|bin|sbin" | xargs -I {} cp -Prf --preserve=mode,timestamps {} $RFSDIR/
    fi
    [ $DESTARCH = arm64 ] && tgtarch=aarch64 || tgtarch=arm
    if update-binfmts --display qemu-$tgtarch 2>/dev/null | grep -q disabled; then
        log_mute update-binfmts --enable qemu-$tgtarch
    fi
    chroot $RFSDIR ldconfig

    fbprint_d "merge apps to $RFSDIR"
}


flexbuild_launch_docker() {
    if ! which docker 1>/dev/null 2>&1; then
        fbprint_e "Ensure docker is installed properly on the host machine!"; exit 1
    fi
    if ! docker ps  1>/dev/null 2>&1; then
        fbprint_e "Ensure you can run 'docker ps' if you are in a docker group"; exit 1
    fi

    docker_hash=$(md5sum "$FBDIR/docker/debian/Dockerfile" | cut -c1-8)
    fbdir_hash=$(echo "$FBDIR" | md5sum | cut -c1-8)
    imagename="fbdebian:${DEBIAN_VERSION}-${docker_hash}"
    containername="$(whoami)_fbdebian_${DEBIAN_VERSION}_${docker_hash}_${fbdir_hash}"

    # check if container exists and get its status (running / exited / not found)
    status=$(docker container inspect -f '{{.State.Status}}' "$containername" 2>/dev/null || true)

    if [ -z "$status" ]; then
        # ensure image exists
		if ! docker image inspect "$imagename" >/dev/null 2>&1; then
			$MAKE -C "$FBDIR/docker/debian" IMAGE_TAG="$imagename" || {
				echo "ERROR: failed to build $imagename" >&2
                return 1
            }
        fi
        docker run -it --hostname fbdebian --name="$containername" --privileged --net=host \
            --add-host fbdebian:127.0.0.1 \
            -v "$HOME":"$HOME" -v "$FBDIR":"$FBDIR" -v /lib/modules:/lib/modules -v /dev:/dev \
            -v /etc/localtime:/etc/localtime:ro -w "$FBDIR" "$imagename" /bin/bash
    elif [ "$status" = "exited" ]; then
		docker start "$containername" >/dev/null
		docker attach "$containername"
    else
        # running -> open an interactive shell in a new session, or attach if you prefer
        docker exec -it "$containername" /bin/bash
    fi
}

check_host_dependent_pkg() {
	fbprint_n "Prepare the build environment on host "

    # for creating .deb package
    if ! command -v fpm >/dev/null 2>&1; then
        log_mute gem install fpm
    fi

    # for imx95 m core toolchain
    if [ ! -d /usr/arm-gnu-toolchain-14.2.rel1-x86_64-arm-none-eabi/bin ] && [ "$CONFIG_SOC_IMX95" = "y" ]; then
        if [ ! -f "$FBDIR/dl/arm-toolchain.tar.xz" ]; then
            rm -rf /tmp/arm-toolchain.tar.xz
            wget --no-check-certificate --tries=3 --timeout=100 --continue --progress=bar --no-verbose --show-progress \
                https://developer.arm.com/-/media/Files/downloads/gnu/14.2.rel1/binrel/arm-gnu-toolchain-14.2.rel1-x86_64-arm-none-eabi.tar.xz \
                -O /tmp/arm-toolchain.tar.xz
            mv /tmp/arm-toolchain.tar.xz $FBDIR/dl/arm-toolchain.tar.xz
        fi
        tar -xf $FBDIR/dl/arm-toolchain.tar.xz -C /usr
    fi
}

generate_wic_img() {
    # Check if flex-installer exists
    if [ ! -f "$FBDIR/tools/flex-installer" ]; then
        fbprint_e "flex-installer not found at $FBDIR/tools/flex-installer"
        exit 1
    fi

    # Check required images exist
	local kernel_mk="$KERNEL_PATH/Makefile"
	local kernelver
    kernelver=$(sed -n 's/^VERSION = //p;s/^PATCHLEVEL = //p;s/^SUBLEVEL = //p' "$kernel_mk" | tr '\n' '.' | sed 's/\.$//')
    local bootimg=boot_${SOCFAMILY}_arm64_lts_${kernelver}.tar.zst
    local rootfsimg=rootfs_${DISTRIB_VERSION}_debian_${MACHINE}.tar.zst

    # Determine firmware image name
    local firmware
    if [[ "$SOCFAMILY" = "LS" ]]; then
        firmware=firmware_${MACHINE}_sdboot.img
    else
        firmware=${MACHINE}-sd-flash.bin
    fi

    # Check if required images exist
    if [ ! -f "$FBOUTDIR/images/$bootimg" ]; then
        fbprint_e "Boot image not found: $FBOUTDIR/images/$bootimg"
        fbprint_w "Please run 'make boot' first"
        exit 1
    fi

    if [ ! -f "$FBOUTDIR/images/$rootfsimg" ]; then
        fbprint_e "Rootfs image not found: $FBOUTDIR/images/$rootfsimg"
        fbprint_w "Please run 'make rfs' or 'make packrfs' first"
        exit 1
    fi

    if [ ! -f "$FBOUTDIR/images/$firmware" ]; then
        fbprint_e "Firmware image not found: $FBOUTDIR/images/$firmware"
        fbprint_w "Please run 'make bsp' first"
        exit 1
    fi

    fbprint_n "Generating WIC image for $MACHINE"

    # Change to images directory to run flex-installer
    cd "$FBOUTDIR/images"

    # Run flex-installer to create WIC image
    $FBDIR/tools/flex-installer -i mkwic \
        -m "$MACHINE" \
        -f "$firmware" \
        -b "$bootimg" \
        -r "$rootfsimg"

    if [ $? -eq 0 ]; then
        local wic_image="rootfs_${DISTRIB_VERSION}_debian_${MACHINE}.wic.zst"
        if [ -f "$FBOUTDIR/images/$wic_image" ]; then
            fbprint_d "WIC image created: $FBOUTDIR/images/$wic_image"
            log_mute ls -lh "$FBOUTDIR/images/$wic_image"
        else
            fbprint_e "WIC image creation failed"
            exit 1
        fi
    else
        fbprint_e "flex-installer mkwic failed"
        exit 1
    fi

    cd "$FBDIR"
}

case "$1" in
    docker)
        flexbuild_launch_docker; exit
        ;;
    distroscr)
        build_bootscr; exit
        ;;
    packrfs)
        pack_distro_rfs; exit
        ;;
    packapp|packapps)
        pack_app_components; exit
        ;;
    itb|mklinux)
        generate_linux_itb; exit
        ;;
    merge-apps)
        merge_apps; exit
        ;;
    host-dep)
        check_host_dependent_pkg; exit
        ;;
    wic)
        generate_wic_img; exit
        ;;
esac

