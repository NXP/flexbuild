# Enable pipefail to ensure pipeline errors are captured
set -o pipefail

# Color definitions for output
GREEN='\e[1;32m'
green='\e[0;32m'
NC='\e[0m'

fbprint_n() { echo -e "${green}\n$1 ${NC}"; }
fbprint_d() { echo -e "${GREEN}$1     [Done] ${NC}"; }

generate_bootpartition_tarball() {
    # Local variable declarations for path safety
    local tiny_itb="$FBOUTDIR/images/${DISTRIB_VERSION}_poky_tiny_${SOCFAMILY}_arm64.itb"
    local bootpartname="boot_${SOCFAMILY}_arm64"
    local bootpartdir="$FBOUTDIR/images/$bootpartname"
    local rootfs_cpio="$FBOUTDIR/images/rootfs_${DISTRIB_VERSION}_poky_tiny_arm64.cpio.gz"
    
    mkdir -p "$bootpartdir"

    # 2. Copy RootFS if exists
    [[ -f "$rootfs_cpio" ]] && cp -f "$rootfs_cpio" "$bootpartdir/"

    fbprint_n "Installing kernel and dtb"
    [[ -f "$tiny_itb" ]] && cp -f "$tiny_itb" "$bootpartdir/"
    
    # Retrieve kernel release version from build artifacts
    local kernel_mk="$KERNEL_PATH/Makefile"
    local kernelrelease
    kernelrelease=$(cat "$KERNEL_OUTPUT_PATH/$KERNEL_BRANCH/include/config/kernel.release" 2>/dev/null)
    
    # Batch copy kernel artifacts using brace expansion
    cp -f "$FBOUTDIR/linux/kernel/arm64/$SOCFAMILY"/{*.dtb,Image*,config-$kernelrelease} "$bootpartdir/"
    cp -f "$FBOUTDIR/linux/kernel/arm64/$SOCFAMILY/vmlinuz-$kernelrelease" "$bootpartdir/"

    # 3. Install kernel modules
    fbprint_n "Installing kernel modules"
    local module_src="$KERNEL_OUTPUT_PATH/$KERNEL_BRANCH/tmp/lib/modules"
    cp -rf "$module_src" "$bootpartdir/"
    
    # Identify module version directory and clean up build/source symlinks
    local modversion
    modversion=$(ls "$module_src" | head -n 1)
    rm -f "$bootpartdir/modules/$modversion"/{build,source}

    # 4. Install distro boot scripts with platform-specific filtering
    fbprint_n "Installing distro boot script"
    if [ "$CONFIG_PLATFORM_LS" = "y" ]; then
        cp -rf "$FBOUTDIR"/boot/LS/*boot.scr "$bootpartdir/"
    else
        cp -rf "$FBOUTDIR"/boot/IMX/*boot.scr "$bootpartdir/"
    fi

    # 5. Handle secure boot headers for Layerscape
    if [ "$CONFIG_PLATFORM_LS" = "y" ] && [ "${CONFIG_SECURE_BOOT}" = "y" ]; then
        cp -rf "$FBOUTDIR/bsp/secboot_hdrs" "$bootpartdir/"
        find "$FBOUTDIR/bsp/secboot_hdrs" -name "*bs.out" | xargs -I {} cp {} "$bootpartdir/"
    fi

    # 6. Extract kernel version components using sed for better performance
    local kernelver
    kernelver=$(sed -n 's/^VERSION = //p;s/^PATCHLEVEL = //p;s/^SUBLEVEL = //p' "$kernel_mk" | tr '\n' '.' | sed 's/\.$//')
    
    local timestamp=$(date +%Y%m%d%H%M)
    local final_name="${bootpartname}_lts_${kernelver}"
    local boottarball="${final_name}_${timestamp}"

    # 7. Create compressed tarball (using -C to avoid unsafe directory switching)
    echo "$boottarball" > "$bootpartdir/buildinfo"
    tar --zstd -cf "$FBOUTDIR/images/$boottarball.tar.zst" -C "$bootpartdir" .

    # 8. Finalize naming and create symbolic links
    rm -rf "$FBOUTDIR/images/$final_name"
    mv "$bootpartdir" "$FBOUTDIR/images/$final_name"
    ln -sf "$boottarball.tar.zst" "$FBOUTDIR/images/$final_name.tar.zst"

    fbprint_d "$FBOUTDIR/images/$boottarball.tar.zst"
}

# Entry point check
if [ "${BASH_SOURCE[0]}" = "$0" ]; then
    # Enable debug trace if LOG_LEVEL is set to 0
    [[ "${LOG_LEVEL}" == "0" ]] && set -x
    generate_bootpartition_tarball "$@"
fi
