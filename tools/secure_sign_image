# signing images for secure boot

source "${FBDIR}/include/console.sh"

secure_sign_image() {
    # $1: <machine>,  $2: <boottype>

    dequote() { printf '%s' "$1" | tr -d '"' | tr -d "'"; }
    local machine="${1:?machine argument is required}"
    local boot_type="${2:?boot_type argument is required}"
    local _distr_ver="$(dequote "${DISTRIB_VERSION:-}")"
    local conf_file="$FBDIR/configs/board/${machine}.conf"
    local cst_dir="$PKGDIR/apps/security/cst"
    local out_hdr_dir="$FBOUTDIR/bsp/secboot_hdrs/${machine}"
    local tiny_itb=$FBOUTDIR/images/${_distr_ver}_poky_tiny_${SOCFAMILY}_arm64.itb
    local kernel_img=$FBOUTDIR/linux/kernel/arm64/$SOCFAMILY/Image

    # 1. Pre-validation: Check configuration existence and required security flags
    [ ! -f "$conf_file" ] && { echo "Error: $conf_file does not exist!"; exit 1; }
    if ! grep -q "IMG4_FILE_${boot_type}_sec" "$conf_file"; then
        return 0
    fi

    # Source board-specific configurations
    . "$conf_file"

    fbprint_n "Signing image for $machine ${boot_type}boot"

    # 2. Workspace Initialization: Prepare CST directory and clean old artifacts
    [ "$ENCAP" = "y" ] && cp "$FBOUTDIR/$bootscript_dec" "$cst_dir/bootscript_dec" && log_mute echo "Copying bootscript_decap"

    cd "$cst_dir" || exit 1
    rm -f bootscript uImage.dtb uImage.bin kernel.itb secboot_hdrs*.bin hdr*.out

    # Batch copy required images to signing workspace
    cp -f "$FBOUTDIR/$distro_bootscript" "bootscript"
    cp -f "$FBOUTDIR/$device_tree"       "uImage.dtb"
    cp -f "$tiny_itb"                    "kernel.itb"
    cp -f "$kernel_img"                  "uImage.bin"

    # 3. RCW Validation: Verify if the boot type is supported for the specific machine
    local rcw_var="rcw_${boot_type}"
    local rcwimg_nonsec="${!rcw_var}" # Bash indirect expansion

    if [[ -z "$rcwimg_nonsec" || "$rcwimg_nonsec" != *"$machine"* ]]; then
        echo "${boot_type}boot on ${machine} is not supported"
        return 1
    fi

    # 4. SoC Specific Logic: Handle LX2160A composite images
    if [ "$CONFIG_SOC_LX2160ARDB" = "y" ]; then
        cp -f "$FBOUTDIR/$COMPOSITE_IMG11_FILE" "$cst_dir/mc.itb"
        cp -f "$FBOUTDIR/$COMPOSITE_IMG12_FILE" "$cst_dir/dpl.dtb"
        cp -f "$FBOUTDIR/$COMPOSITE_IMG13_FILE" "$cst_dir/dpc.dtb"
    fi

    # 5. Signing Execution: Execute the corresponding script based on boot media
    mkdir -p "$out_hdr_dir"
    case "$boot_type" in
        nand)             [ -n "$nand_script" ] && log_mute . "$nand_script" ;;
        sd|emmc)          [ -n "$sd_script" ]   && log_mute . "$sd_script"   ;;
        nor|qspi|xspi)
            local script_var="${boot_type}_script"
            [ -n "${!script_var}" ] && log_mute . "${!script_var}" ;;
    esac

    # 6. Artifact Collection: Move signed headers to the output directory
    if [ "$CONFIG_SOC_LS1028ARDB" = "y" ]; then
        # Special case for LS1028A naming convention
        cp -f "$cst_dir/secboot_hdrs.bin" "$out_hdr_dir/secboot_hdrs_${boot_type}boot.bin"
    else
        cp -f "$cst_dir/secboot_hdrs_${boot_type}boot.bin" "$out_hdr_dir/"
    fi

    # Copy common signed output files
    cp -f "$cst_dir/hdr_dtb.out"   "$out_hdr_dir/"
    cp -f "$cst_dir/hdr_linux.out" "$out_hdr_dir/"
    cp -f "$cst_dir/hdr_bs.out"    "$out_hdr_dir/hdr_${machine}_bs.out"

    # Handle optional components (Encapsulation and IMA/EVM)
    [ "$ENCAP" = "y" ] && cp -f "$cst_dir/hdr_bs_dec.out" "$out_hdr_dir/hdr_${machine}_bs_dec.out"

    if [ "$IMA_EVM" = "y" ]; then
        cp -f "$cst_dir/hdr_bs_enf.out"    "$out_hdr_dir/hdr_${machine}_bs_enf.out"
        cp -f "$cst_dir/hdr_initramfs.out" "$out_hdr_dir/"
    fi

    fbprint_d "Signing image for $machine ${boot_type}boot"
}

if [ "${BASH_SOURCE[0]}" = "$0" ]; then
    # Enable debug trace if LOG_LEVEL is set to 0
    [[ "${LOG_LEVEL}" == "0" ]] && set -x
    secure_sign_image "$@"
fi
