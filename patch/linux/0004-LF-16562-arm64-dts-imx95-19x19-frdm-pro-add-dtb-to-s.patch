From 95f9961827e8e562a7290917fa3331eb39624eed Mon Sep 17 00:00:00 2001
From: Yuantian Tang <andy.tang@nxp.com>
Date: Mon, 26 Jan 2026 23:38:48 -0800
Subject: [PATCH 4/5] LF-16562: arm64: dts: imx95-19x19-frdm-pro: add dtb to
 support waveshare 7inch panel

Since FRDM-IMX95 and FRDM-IMX95-pro have similar design on DSI display.
Move the common code from imx95-15x15-frdm-waveshare-7-inch-c-panel.dtso
to common dtsi.
Both boards use the common dtsi code to support the waveshare 7 inch panel.

Signed-off-by: Joseph Guo <qijian.guo@nxp.com>
Acked-by: Liu Ying <victor.liu@nxp.com>
---
 arch/arm64/boot/dts/freescale/Makefile        |   3 +
 ...95-15x15-frdm-waveshare-7inch-c-panel.dtso | 110 +-----------------
 ...9x19-frdm-pro-waveshare-7inch-c-panel.dtso |  17 +++
 ...5-frdm-waveshare-7inch-c-panel-common.dtsi | 105 +++++++++++++++++
 4 files changed, 126 insertions(+), 109 deletions(-)
 create mode 100644 arch/arm64/boot/dts/freescale/imx95-19x19-frdm-pro-waveshare-7inch-c-panel.dtso
 create mode 100644 arch/arm64/boot/dts/freescale/imx95-frdm-waveshare-7inch-c-panel-common.dtsi

diff --git a/arch/arm64/boot/dts/freescale/Makefile b/arch/arm64/boot/dts/freescale/Makefile
index b459f5d07b30..6c0002f95b43 100644
--- a/arch/arm64/boot/dts/freescale/Makefile
+++ b/arch/arm64/boot/dts/freescale/Makefile
@@ -965,6 +965,9 @@ imx95-19x19-frdm-pro-dual-os08a20-isp-dtbs := imx95-19x19-frdm-pro.dtb \
 					      imx95-19x19-frdm-pro-os08a20-combo.dtbo
 dtb-$(CONFIG_ARCH_MXC) += imx95-19x19-frdm-pro-dual-os08a20-isp.dtb
 
+imx95-19x19-frdm-pro-waveshare-7inch-c-panel-dtbs := imx95-19x19-frdm-pro.dtb \
+						     imx95-19x19-frdm-pro-waveshare-7inch-c-panel.dtbo
+dtb-$(CONFIG_ARCH_MXC) += imx95-19x19-frdm-pro-waveshare-7inch-c-panel.dtb
 
 dtb-$(CONFIG_ARCH_S32) += s32g274a-evb.dtb
 dtb-$(CONFIG_ARCH_S32) += s32g274a-rdb2.dtb
diff --git a/arch/arm64/boot/dts/freescale/imx95-15x15-frdm-waveshare-7inch-c-panel.dtso b/arch/arm64/boot/dts/freescale/imx95-15x15-frdm-waveshare-7inch-c-panel.dtso
index 0be540eec955..f4e042e749b0 100644
--- a/arch/arm64/boot/dts/freescale/imx95-15x15-frdm-waveshare-7inch-c-panel.dtso
+++ b/arch/arm64/boot/dts/freescale/imx95-15x15-frdm-waveshare-7inch-c-panel.dtso
@@ -3,106 +3,7 @@
  * Copyright 2025 NXP
  */
 
