[ -n "$MKDEBUG" ] && SHFLAGS="-ex -o pipefail -c" || SHFLAGS="-c "
FB_VERSION=2606

usage () {
cat <<EOF
Usage: bld -m <machine>
   or  bld <target> [ <option> ]

Most used example with automated build:
 bld -m imx8mpevk                # automatically build BSP + kernel + NXP-specific components + Debian RootFS for imx8mpevk platform
 bld -m lx2160ardb               # same as above, for lx2160ardb platform

Most used example with separate command:
 bld bsp -m <machine>             # generate BSP composite firmware (including atf/u-boot/kernel/dtb/peripheral-firmware/initramfs) for <machine>
 bld atf -m <machine> -b sd      # compile atf image for SD boot on <machine>
 bld boot -m <machine>           # generate boot partition tarball (including kernel,dtb,modules,distro bootscript) for <machine>
 bld linux -m <machine>          # compile linux kernel for <machine>

 bld apps -m <machine>           # compile NXP-specific components against the runtime dependencies for <machine>
 bld merge-apps -m <machine>     # merge NXP-specific components into <machine> Debian rootfs

 bld rfs -m <machine>            # generate Debian-based rootfs for <machine>
 bld packrfs -m <machine>        # pack and compress target rootfs as rootfs_<distro_version>_debian_<machine>_arm64.tar.zst

 bld clean-bsp                   # clean obsolete BSP (u-boot/atf/firmware) images
 bld clean-linux                 # clean obsolete linux image
 bld clean-apps -m <machine>     # clean the obsolete <machine>-specific apps components binary images
 bld clean -m <machine>          # equal to "bld clean bsp" + "bld clean linux" + "bld clean-apps -m <machine>"
 bld clean-rfs -m <machine>      # clean target debian-based rootfs for <machine>

 bld docker                      # create or attach docker container to build in docker
 bld list                        # list enabled machines and supported various components

Most used options:
 -m, --machine         target machine, e.g. imx8mpevk, imx8mmevk, imx91frdm, imx93frdm, imx93evk, lx2160ardb, ls1046ardb, ls1028ardb, etc
 -b, --boottype        type of boot media, valid argument: sd, emmc, nor, qspi, xspi, nand. for imx platform, only sd boot is supported.
 -s, --secure          Enable secure boot option for Layerscape platform.
 -o, --optee           Enable OPTEE function for target platform.

See docs/flexbuild_usage.md and docs/build_and_deploy_distro.md for more information about the available commands.
EOF
   exit
}


check_toolchain() {
    tc_version='12.x or 13.x or 14.x'
    if [ $DESTARCH = arm64 ] && [ $HOSTARCH = x86_64 -o $HOSTARCH = armv7l -o $HOSTARCH = i686 ]; then
        [ -f /usr/bin/aarch64-linux-gnu-gcc ] && gccversion=$(aarch64-linux-gnu-gcc --version | head -1 | cut -d' ' -f4) || gccversion=0
        if [ $gccversion = 0 ]; then
            fbprint_w "Installing toolchain for arm64"
            log_mute apt-get install -y crossbuild-essential-arm64 gcc-aarch64-linux-gnu g++-aarch64-linux-gnu binutils-aarch64-linux-gnu
        elif ! echo $tc_version | grep -q `echo $gccversion | cut -d. -f1` &&  [ $DISTROTYPE != buildroot ]; then
            fbprint_w "The existing toolchain version $gccversion on this host may result in build failure for some components."
            fbprint_w "Please build on Debian $DEBIAN_VERSION or Ubuntu 22.04 host or build in docker (run 'bld docker') to use the verified toolchain version $tc_version"
            exit
        fi
        export ARCH=arm64
        export CROSS_COMPILE=aarch64-linux-gnu-
    elif [ $HOSTARCH = aarch64 -o $HOSTARCH = armv7l ]; then
        export ARCH=arm64
        export CROSS_COMPILE=aarch64-linux-gnu-
    fi
}


generate_initrd_cpio() {
    [ -f $RFSDIR/etc/buildinfo ] || bld rfs -r $DISTROTYPE:$DISTROVARIANT -a $DESTARCH -m $MACHINE
    fbprint_n "Generating ${initrdimg##*/}"
    if [ -d $RFSDIR/sys/devices ]; then
        [ -d $RFSDIR/sys/kernel/security ] && sudo umount $RFSDIR/sys/kernel/security || true
        sudo umount $RFSDIR/sys
    fi
    [ -f $RFSDIR/proc/uptime ] && sudo umount $RFSDIR/proc
    [ -c $RFSDIR/dev/pts/0 ] && sudo umount $RFSDIR/dev/pts
    cd $RFSDIR && sudo find . | sudo cpio --quiet -o -H newc | gzip > $FBOUTDIR/images/${initrdimg##*/} && \
    log_mute ls -lh $FBOUTDIR/images/${initrdimg##*/} && fbprint_d "$FBOUTDIR/images/${initrdimg##*/}"
}


generate_linux_itb() {
    # Define paths for initrd and output ITB image
    local initrdimg="$FBOUTDIR/images/rootfs_${DISTRIB_VERSION}_poky_tiny_arm64.cpio.gz"
    local linux_itb="$FBOUTDIR/images/${DISTRIB_VERSION}_poky_tiny_${SOCFAMILY}_arm64.itb"
    local its_template="$FBDIR/configs/linux/linux_${DESTARCH}_${SOCFAMILY}.its"

    # Ensure initrd exists; fetch prebuilt if missing
    [ -f "$initrdimg" ] || get_prebuilt_initrd

    # Create a unique temporary ITS file to prevent race conditions during parallel builds
    local tmpits
    tmpits=$(mktemp --suffix=.its)

    # Ensure temporary file is removed even if the script exits prematurely (set -e)
    trap 'rm -f "$tmpits"' EXIT

    # Prepare the ITS file by replacing placeholders with actual environment paths
    cp -f "$its_template" "$tmpits"
    sed -i "s|../../build|${FBOUTDIR}|g" "$tmpits"
    sed -i "s/rootfs_poky_tiny_${DESTARCH}/rootfs_${DISTRIB_VERSION}_poky_tiny_arm64/" "$tmpits"

    # Generate the FIT image; mkimage will trigger set -e and exit if it fails
    mkimage -f "$tmpits" "$linux_itb" >/dev/null

    # Display the final image path on success
    fbprint_d "$linux_itb"
}


generate_distro_bootscr() {
    # $1: machine name
    local machine="$1"
    local conf_file="$FBDIR/configs/board/${machine}.conf"

    # 1. Configuration File Validation
    if [[ ! -f "$conf_file" ]]; then
        echo "Error: Configuration file not found at ${conf_file}"
        return 1
    fi


    # 3. Load Board Configuration and Setup Directories
    # shellcheck source=/dev/null
    source "$conf_file"

    # 4. Generate Distro Boot Script
    local out_base="$FBOUTDIR"
    if [[ "$machine" =~ ^(ls|lx) ]]; then
        plat="LS"
    else
        plat="IMX"
    fi
    local bootdir="boot/${plat}/${machine}_boot.scr"
    local tmp_scr="${out_base}/${bootdir}.tmp"

    # Ensure target directory exists
    mkdir -p "${out_base}/${bootdir%/*}"

    # Handle Secure Validation logic
    if [[ -n "$securevalidate" ]]; then
        echo "$securevalidate" > "$tmp_scr"
    fi

    echo "$distroboot" >> "$tmp_scr"

    # Wrap the temporary script into a U-Boot image format
    log_mute mkimage -A arm64 -O linux -T script -C none -a 0 -e 0 \
        -n "boot.scr" -d "$tmp_scr" "${out_base}/$bootdir"

    rm -f "$tmp_scr"
    fbprint_d "${out_base}/$bootdir"
}

build_bootscr() {
    CONF_FILE="${FBDIR}/configs/board/${SOCFAMILY}_boot.txt"
    OUT_PATH="${FBOUTDIR}/boot/${SOCFAMILY}_boot.scr"

    if [ ! -f "$CONF_FILE" ]; then
        echo "Error: Configuration file not found at $CONF_FILE"
        exit 1
    fi

    mkdir -p "$(dirname "$OUT_PATH")"

    log_mute mkimage -A arm64 -O linux -T script -C none -a 0 -e 0 -n "boot.scr" -d "$CONF_FILE" "$OUT_PATH"

    if [ $? -eq 0 ]; then
        echo "Success: Created $OUT_PATH"
    else
        echo "Error: mkimage failed"
        exit 1
    fi
}

check_http_request() {
    retcode=$(curl -I -m 10 -o /dev/null -s -w %{http_code} $1) || true
    if [ $retcode != 000 -a ${retcode:0:1} != 2 -a ${retcode:0:1} != 3 ]; then
        fbprint_e "ERROR: HTTP returned $retcode, failed to access $1"
        fbprint_e "Please check your network to ensure $1 is accessable via HTTP from this machine"
        fbprint_e "Please check HTTP proxy settings if it is needed in your environment" && exit
    fi
    [ $retcode != 200 -a $retcode != 000 ] && fbprint_e "The requested URL $1 returned error $retcode" && exit 1 || true
}


get_prebuilt_initrd() {
    tfile=rootfs_${DISTRIB_VERSION}_poky_tiny_arm64.cpio.gz
    if [ ! -f $FBOUTDIR/images/$tfile ]; then
        [ $HOSTARCH = x86_64 ] && check_http_request $initrd_bin_url/$tfile
        rm -f /tmp/$tfile
        log_mute wget --no-check-certificate --tries=3 --timeout=100 --continue --progress=bar --no-verbose --show-progress \
            $DISTRO_SVR_URL/$DISTRIB_VERSION/$tfile -O /tmp/$tfile
        mv /tmp/$tfile $FBOUTDIR/images/$tfile
    fi
}


rfs_umount() {
	for mnt in dev/pts dev sys/kernel/security sys  proc; do
		 if mountpoint -q "$1/$mnt"; then
			 if ! umount "$1/$mnt"; then
				 sleep 2
				 umount -f "$1/$mnt" || true
				 log_mute echo umount $1/$mnt failed
			 else
				 log_mute echo umont $mnt successfully
			 fi
		 else
			 log_mute echo $mnt is not mounted.
		 fi
	done
}

rfs_mount() {
	if ! mountpoint -q "$1/proc"; then
		mount -t proc /proc "$1/proc"
	fi
	if ! mountpoint -q "$1/sys"; then
		mount -t sysfs /sys "$1/sys"
	fi
	if ! mountpoint -q "$1/dev"; then
		mount --bind /dev "$1/dev"
	fi
	if ! mountpoint -q "$1/dev/pts"; then
		mount --bind /dev/pts "$1/dev/pts"
	fi
}


pack_distro_rfs() {
    [ -f $RFSDIR/etc/buildinfo ] || { fbprint_e "$RFSDIR is incomplete"; exit; }
    [ $DISTROTYPE = ubuntu -o $DISTROTYPE = debian ] && rfs_umount "$RFSDIR"

    local rname=${RFSDIR##*/}
    local tarname=${rname}_`date +%Y%m%d%H%M`.tar.zst

    fbprint_n "Generating $tarname"
    cd $RFSDIR && tar -C "$RFSDIR" \
          --anchored \
          --exclude='./proc' --exclude='./proc/*' \
          --exclude='./sys'  --exclude='./sys/*'  \
          --exclude='./dev'  --exclude='./dev/*'  \
          --exclude='./run'  --exclude='./run/*'  \
          -cf - . | \
          pzstd -q -o "$FBOUTDIR/images/$tarname"
    cd $FBOUTDIR/images && ln -sf $tarname $FBOUTDIR/images/${rname}.tar.zst && cd $FBDIR
    log_mute ls -lh $FBOUTDIR/images/${rname}*
    fbprint_d $FBOUTDIR/images/$tarname
}


pack_app_components() {
	local appdeb_sym=nxp_apps_debian_${DISTRIB_VERSION}_${MACHINE}_`date +%Y%m%d%H%M`.deb
	local appdeb=nxp_apps_debian_${DISTRIB_VERSION}_${MACHINE}.deb
	local ver="${DISTRIB_VERSION:4}"
	echo packing $appdeb
	cd $FBOUTDIR/images
	fpm -s dir -t deb -n $appdeb -v $ver -a arm64 --deb-no-default-config-files --package $appdeb_sym \
		"${FBOUTDIR}"/apps/apps_${DISTROTYPE}_${MACHINE}/=/ 2>/dev/null
	ln -sf $appdeb_sym $FBOUTDIR/images/$appdeb
	fbprint_d $FBOUTDIR/images/${appdeb_sym}
}


merge_apps() {
    [ ! -f $RFSDIR/etc/buildinfo ] && build_distro_rfs_debian

    if [ $DISTROTYPE = debian -o $DISTROTYPE = ubuntu ] && [ $DISTROVARIANT != base ]; then
        if [ $DESTDIR != $RFSDIR ]; then
            for dir in lib bin sbin; do
                [ -d $DESTDIR/$dir ] && cp -Prf --preserve=mode,timestamps $DESTDIR/$dir/* $RFSDIR/$dir/
            done
            ls -d $DESTDIR/* | grep -v -E "lib|bin|sbin" | xargs -I {} cp -Prf --preserve=mode,timestamps {} $RFSDIR/
        fi
        [ $DESTARCH = arm64 ] && tgtarch=aarch64 || tgtarch=arm
        if update-binfmts --display qemu-$tgtarch 2>/dev/null | grep -q disabled; then
            log_mute update-binfmts --enable qemu-$tgtarch
        fi
        chroot $RFSDIR ldconfig
    fi
    fbprint_d "merge apps to $RFSDIR"
}


