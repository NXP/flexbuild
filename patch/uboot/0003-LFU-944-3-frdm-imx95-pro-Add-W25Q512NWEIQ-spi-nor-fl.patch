From 60cea5819361575c26a084d03faac0124cbbb498 Mon Sep 17 00:00:00 2001
From: fushi <fushi.peng@nxp.com>
Date: Tue, 16 Sep 2025 10:37:02 +0800
Subject: [PATCH 3/3] LFU-944-3: frdm-imx95-pro: Add W25Q512NWEIQ spi nor flash
 support

Add dts and defconfig file to support W25Q512NWEIQ for
FRDM-IMX95-PRO board.

Signed-off-by: fushi <fushi.peng@nxp.com>
Reviewed-by: Ye Li <ye.li@nxp.com>
---
 arch/arm/dts/imx95-19x19-frdm-pro-u-boot.dtsi |  12 +
 arch/arm/dts/imx95-19x19-frdm-pro.dts         |  32 +++
 configs/imx95_19x19_frdm_pro_fspi_defconfig   | 239 ++++++++++++++++++
 3 files changed, 283 insertions(+)
 create mode 100644 configs/imx95_19x19_frdm_pro_fspi_defconfig

diff --git a/arch/arm/dts/imx95-19x19-frdm-pro-u-boot.dtsi b/arch/arm/dts/imx95-19x19-frdm-pro-u-boot.dtsi
index 1032d619ae0..37171689f65 100644
--- a/arch/arm/dts/imx95-19x19-frdm-pro-u-boot.dtsi
+++ b/arch/arm/dts/imx95-19x19-frdm-pro-u-boot.dtsi
@@ -15,6 +15,14 @@
 	/delete-property/ assigned-clock-parents;
 };
 
+&flexspi1 {
+	bootph-pre-ram;
+
+	flash@0{
+		bootph-pre-ram;
+	};
+};
+
 &lpi2c3 {
 	bootph-some-ram;
 };
@@ -28,6 +36,10 @@
 	assigned-clock-parents = <&scmi_clk IMX95_CLK_VIDEOPLL1>;
 };
 
+&pinctrl_flexspi1 {
+	bootph-pre-ram;
+};
+
 &pinctrl_uart1 {
 	bootph-pre-ram;
 };
diff --git a/arch/arm/dts/imx95-19x19-frdm-pro.dts b/arch/arm/dts/imx95-19x19-frdm-pro.dts
index 18b9f5d51e7..95c4cd9ab49 100644
--- a/arch/arm/dts/imx95-19x19-frdm-pro.dts
+++ b/arch/arm/dts/imx95-19x19-frdm-pro.dts
@@ -40,6 +40,7 @@
 		serial7 = &lpuart8;
 		ethernet0 = &enetc_port0;
 		ethernet1 = &enetc_port1;
+		spi0 = &flexspi1;
 	};
 
 	chosen {
@@ -108,6 +109,25 @@
 	status = "okay";
 };
 
+&flexspi1 {
+	bootph-pre-ram;
+	pinctrl-names = "default";
+	pinctrl-0 = <&pinctrl_flexspi1>;
+	assigned-clock-rates = <133000000>;
+	status = "okay";
+
+	flash0: flash@0 {
+		bootph-pre-ram;
+		reg = <0>;
+		#address-cells = <1>;
+		#size-cells = <1>;
+		compatible = "jedec,spi-nor";
+		spi-max-frequency = <133000000>;
+		spi-tx-bus-width = <4>;
+		spi-rx-bus-width = <4>;
+	};
+};
+
 &netc_emdio {
 	pinctrl-names = "default";
 	pinctrl-0 = <&pinctrl_emdio>;
@@ -491,4 +511,16 @@
 			IMX95_PAD_SD2_VSELECT__USDHC2_VSELECT			0x51e
 		>;
 	};
+
+	pinctrl_flexspi1: flexspi1grp {
+		fsl,pins = <
+			IMX95_PAD_XSPI1_SS0_B__FLEXSPI1_A_SS0_B			0x3fe
+			IMX95_PAD_XSPI1_SCLK__FLEXSPI1_A_SCLK			0x3fe
+			IMX95_PAD_XSPI1_DATA0__FLEXSPI1_A_DATA_BIT0		0x3fe
+			IMX95_PAD_XSPI1_DATA1__FLEXSPI1_A_DATA_BIT1		0x3fe
+			IMX95_PAD_XSPI1_DATA2__FLEXSPI1_A_DATA_BIT2		0x3fe
+			IMX95_PAD_XSPI1_DATA3__FLEXSPI1_A_DATA_BIT3		0x3fe
+		>;
+	};
+
 };
diff --git a/configs/imx95_19x19_frdm_pro_fspi_defconfig b/configs/imx95_19x19_frdm_pro_fspi_defconfig
new file mode 100644
