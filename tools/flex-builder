check_binfmt_qemu() {
    if grep -q Ubuntu /etc/os-release; then
        [ -f /usr/bin/qemu-aarch64-static ] || \
        { log_mute sudo apt-get update; log_mute sudo apt-get install -y binfmt-support qemu-system-common qemu-user-static; }
    fi
    if ! grep -q binfmt_misc /proc/filesystems; then
        sudo modprobe binfmt_misc
    fi
}


flexbuild_launch_docker() {
    dnum=$(printf '%s' "$FBDIR" | md5sum | cut -c1-6)
    containername="${username}_fbdebian_${DEBIAN_VERSION}_${dnum}"

    # check if container exists and get its status (running / exited / not found)
    status=$(docker container inspect -f '{{.State.Status}}' "$containername" 2>/dev/null || true)

    if [ -z "$status" ]; then
        # ensure image exists
        if ! docker image inspect "fbdebian:${DEBIAN_VERSION}" >/dev/null 2>&1; then
            $MAKE -C "$FBDIR/docker/debian" || {
                echo "ERROR: failed to build fbdebian:${DEBIAN_VERSION}" >&2
                return 1
            }
        fi

        docker run -it --hostname fbdebian --name="$containername" --privileged --net=host \
            -v "$HOME":"$HOME" -v "$FBDIR":"$FBDIR" -v /lib/modules:/lib/modules -v /dev:/dev \
            -v /etc/localtime:/etc/localtime:ro -w "$FBDIR" "fbdebian:${DEBIAN_VERSION}" /bin/bash
    elif [ "$status" = "exited" ]; then
        docker start -ai "$containername"
    else
        # running -> open an interactive shell in a new session, or attach if you prefer
        docker exec -it "$containername" /bin/bash
    fi
}


flex_auto_build() {
    if echo "$BUILDARG" | grep -q fragment:; then
        export FRAGMENT_CFG=$(echo $BUILDARG | cut -d: -f2); unset BUILDARG
        elif [ -n "$BUILDARG" ]; then
        fbprint_w "Warning: ignored invalid -B $BUILDARG for autobuild"; unset BUILDARG
    fi

    echo "Time of fetching repo: `date`"
    [ -d $FBDIR/.git ] && echo Flexbuild HEAD commit: `git log -1 --oneline`

    echo "Time of build: `date`"
    starttime=`date +'%Y-%m-%d %H:%M:%S'`

    DISTROVARIANT=server
    bld linux -m $MACHINE
    bld linux-headers -m $MACHINE
    bld linux-modules -m $MACHINE
    bld rfs -m $MACHINE
    bld apps -m $MACHINE
    bld itb -r poky:tiny -a $DESTARCH -p $SOCFAMILY
    bld distroscr -m $MACHINE
    bld bsp -m $MACHINE
    bld boot -m $MACHINE

    bld merge-apps -m $MACHINE
    bld packrfs -m $MACHINE

    cp -f $FBDIR/tools/flex-installer $FBOUTDIR/images
	log_mute ls -goh $FBOUTDIR/images

    fbprint_n "Build Done: `date`"
    endtime=`date +'%Y-%m-%d %H:%M:%S'`
    start_seconds=$(date --date="$starttime" +%s)
    end_seconds=$(date --date="$endtime" +%s)
    spent=$((end_seconds-start_seconds))
    mins=`expr $(echo $(($spent))) / 60`
    secs=`expr $(echo $(($spent))) % 60`
    fbprint_n "Duration of build: $mins minutes $secs seconds"
}


flex_autobuild_all() {
    bld auto_build -a $DESTARCH 2>&1 | \
    tee $FBDIR/logs/autobuild-${MACHINE}-log-`date +%Y%m%d%H%M`.txt
}

check_proxy() {
    aptfile=$1/etc/apt/apt.conf
    for hproto in http https; do
    hproxy=${hproto}_proxy && hproxy=`eval echo '${'"$hproto""_proxy"'}'`
    if [ -n "$hproxy" ]; then
        [ -f $aptfile ] || touch $aptfile
        if ! grep -q ^Acquire::$hproto::proxy $aptfile; then
            echo "Acquire::$hproto::proxy \"$hproxy/\";" | tee -a $aptfile 1>/dev/null
        fi
    fi
    done
}

check_debian_version() {
    if [[ ! -f /etc/os-release ]] || [[ ! `cat /etc/issue | grep -iE '^Debian GNU/Linux 13'` ]]; then
        fbprint_w "The host is not Debian 13 system, please install docker (refer to docs/FAQ-docker-setup.md) and run 'bld docker' to build in docker" && exit
    else
        [ -f /usr/bin/lsb_release ] || log_mute sudo apt-get install -y lsb-release
        [ ! -f /usr/bin/lsb_release ] && fbprint_e "lsb_release command is not found" && exit
        releaseVersion=$(lsb_release -rs)
        result=$(echo "$releaseVersion < $DEBIAN_VERSION" | bc)
        if [ "$result" -eq "1" ]; then
            fbprint_e "The distro version installed on this host is older than Debian $DEBIAN_VERSION"
            fbprint_e "please upgrade it or install docker and run 'bld docker' to build in docker" && exit
        else
            check_binfmt_qemu
        fi
    fi
}

check_host_dependent_pkg() {
	fbprint_n "Prepare the build environment on host "

    if [ ! -f ~/.gitconfig ] || [[ ! `grep 'name =' ~/.gitconfig` ]]; then
        git config --global user.email  "`whoami`@nxp.com"
        git config --global user.name "`whoami`"
        if [ -n "$http_proxy" ] && [[ ! `grep 'proxy =' ~/.gitconfig` ]]; then
            git config --global http.proxy $http_proxy
            git config --global https.proxy $https_proxy
        fi
        git config --global --add safe.directory '*'
    fi
    [ `hostname` = fbdebian ] && nflag=.deppkgdonefbdeb || nflag=.deppkgdone
    check_toolchain && touch $FBDIR/logs/$nflag

    # for creating .deb package
    if ! command -v fpm >/dev/null 2>&1; then
        log_mute gem install fpm
    fi

    # for imx95 m core toolchain
    if [ ! -d /usr/arm-gnu-toolchain-14.2.rel1-x86_64-arm-none-eabi/bin ] && [ "$CONFIG_SOC_IMX95" = "y" ]; then
        if [ ! -f "$FBDIR/dl/arm-toolchain.tar.xz" ]; then
            rm -rf /tmp/arm-toolchain.tar.xz
            wget --no-check-certificate --tries=3 --timeout=100 --continue --progress=bar --no-verbose --show-progress \
                https://developer.arm.com/-/media/Files/downloads/gnu/14.2.rel1/binrel/arm-gnu-toolchain-14.2.rel1-x86_64-arm-none-eabi.tar.xz \
                -O /tmp/arm-toolchain.tar.xz
            mv /tmp/arm-toolchain.tar.xz $FBDIR/dl/arm-toolchain.tar.xz
        fi
        tar -xf $FBDIR/dl/arm-toolchain.tar.xz -C /usr
    fi
}

check_linux_config() {
    [ $DESTARCH = arm32 ] && tarch=arm || tarch=arm64
    if [ -n "$FRAGMENT_CFG" ]; then
        for cfg in $FRAGMENT_CFG; do
            [ -f $KERNEL_PATH/arch/$tarch/configs/$cfg ] || \
            cp -f $FBDIR/configs/linux/$cfg $KERNEL_PATH/arch/$tarch/configs
        done
    fi
}

do_clean() {
	local has_valid=0
	for arg in "${@:2}"; do
		has_valid=1
		if ! echo $APPS_REPO_LIST utils security networking graphics multimedia ml gopoint robotics | grep -q $arg; then
			echo "Invalid component: $arg"; echo;  continue;
		fi

		for valid_arg in $APPS_REPO_LIST; do
			if [ "$arg" = "$valid_arg" ]; then
				rm -rf $PKGDIR/apps/*/$arg 2>/dev/null
				echo "Clean components: $arg"; echo
			fi
		done
		if [ -d $PKGDIR/apps/$arg ]; then
			rm -rf $PKGDIR/apps/$arg
			echo "Clean components: $arg"; echo
		fi
	done
	[ $has_valid = 1 ] && return 0

    rm -rf $FBOUTDIR/images/*
    clean_bsp_components
    clean_linux_components
    clean_apps_components
    rm -f $FBDIR/logs/*
    fbprint_d "clean all old images except distro rootfs"
}

do_clean_rfs() {
    if [ $DISTROTYPE = poky ]; then
        echo cleaning $pokytmpdir && rm -rf $pokytmpdir
        rm -rf $FBOUTDIR/rfs/rootfs_${DISTRIB_VERSION}_poky_${DISTROVARIANT}_${DESTARCH}
        fbprint_d "clean $pokytmpdir"
    elif [ $DISTROTYPE = buildroot ]; then
        rm -rf ${RFSDIR%/*}
        fbprint_d "clean ${RFSDIR%/*}"
    else
		rfs_umount "$RFSDIR"
        rm -rf $RFSDIR && rm -rf $FBOUTDIR/images/${RFSDIR##*/}*
        fbprint_d "clean distro $RFSDIR"
    fi
}

