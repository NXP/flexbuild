@@ -114,12 +15,3 @@ channel@0 {
 		status = "okay";
 	};
 };
-
-&scmi_iomuxc {
-	pinctrl_lpi2c6: lpi2c6grp {
-		fsl,pins = <
-			IMX95_PAD_GPIO_IO02__LPI2C6_SDA			0x40000b9e
-			IMX95_PAD_GPIO_IO03__LPI2C6_SCL			0x40000b9e
