#
# config RFS for each board
# $1=$MACHINE $2=$RFSDIR
#
debian_rfs_post_config() {

	echo "Setup $1 ..."
	case "$1" in
		imx8mm*)
			sed -i "s/.*pam_nologin.*/auth    requisite       pam_nologin.so nullok/" $RFSDIR/etc/pam.d/gdm-password
			sed -e  's/.*AutomaticLoginEnable.*/AutomaticLoginEnable = true/'  -e '0,/user1/s/.*user1.*/AutomaticLogin = debian/'  -i $2/etc/gdm3/daemon.conf
			sed -i '$a\[Install]\nWantedBy=graphical.target\n' $2/lib/systemd/system/gdm.service
			#rm -rf $2/etc/systemd/system/display-manager.service
			ln -sf /lib/systemd/system/gdm.service $2/etc/systemd/system/graphical.target.wants/gdm.service
			ln -sf vsidaemon-IMX8MM $2/usr/bin/vsidaemon
			/usr/bin/sed -i '/^gbm-format=argb8888/s/^/# /' $2/etc/xdg/weston/weston.ini
			/usr/bin/sed -i '/^xwayland=true$/a modules=screen-share.so' $2/etc/xdg/weston/weston.ini
            /usr/bin/patchelf --replace-needed libGL.so.1 libGLESv2.so.2 $2/lib/aarch64-linux-gnu/libmutter-16.so.0.0.0

			;;

		imx8mp*)
			sed -i "s/.*pam_nologin.*/auth    requisite       pam_nologin.so nullok/" $2/etc/pam.d/gdm-password
			sed -e  's/.*AutomaticLoginEnable.*/AutomaticLoginEnable = true/'  -e '0,/user1/s/.*user1.*/AutomaticLogin = debian/'  -i $2/etc/gdm3/daemon.conf
			sed -i '$a\[Install]\nWantedBy=graphical.target\n' $2/lib/systemd/system/gdm.service
			#rm -rf $2/etc/systemd/system/display-manager.service
			ln -sf /lib/systemd/system/gdm.service $2/etc/systemd/system/graphical.target.wants/gdm.service
			ln -sf /lib/systemd/system/imx8-isp.service $2/etc/systemd/system/multi-user.target.wants/imx8-isp.service
			ln -sf vsidaemon-IMX8MP $2/usr/bin/vsidaemon
            /usr/bin/patchelf --replace-needed libGL.so.1 libGLESv2.so.2 $2/lib/aarch64-linux-gnu/libmutter-16.so.0.0.0
			;;

		imx91*)
			sed -i '/^use-g2d=true/s/^/# /' $2/etc/xdg/weston/weston.ini
			sed -i '/^gbm-format=argb8888/s/^/# /' $2/etc/xdg/weston/weston.ini
			sed -i '/gopoint/d' $2/etc/xdg/weston/weston.ini
			ln -sf /lib/systemd/system/weston.service $2/etc/systemd/system/graphical.target.wants/weston.service
			;;

		imx93*)
			ln -sf libg2d-pxp.so.2.4.0 $2/usr/lib/libg2d.so.2
            [ -f $2/usr/lib/libg2d-viv.so.2.4.0 ] && rm -f $2/usr/lib/libg2d-viv.so.2.4.0
			sed -i '/^xwayland=true$/a modules=screen-share.so' $2/etc/xdg/weston/weston.ini
			ln -sf /lib/systemd/system/weston.service $2/etc/systemd/system/graphical.target.wants/weston.service
            rm -rf $2/etc/systemd/system/display-manager.service
            rm -rf $2/usr/lib/{libGLESv2.so*,libEGL.so*,libcogl.so*,libgstallocators-1.0.so,libvulkan.so}
            rm -rf $2/usr/lib/{libdrm.so*,libgbm.so*,libgbm_viv.so}
            rm -rf $2/usr/lib/libclutter-gst-3.0.so*

			;;

		ls1028a*)
			sed -i "s/.*pam_nologin.*/auth    requisite       pam_nologin.so nullok/" $2/etc/pam.d/gdm-password
			sed -e  's/.*AutomaticLoginEnable.*/AutomaticLoginEnable = true/'  -e '0,/user1/s/.*user1.*/AutomaticLogin = debian/'  -i $2/etc/gdm3/daemon.conf
			sed -i '$a\[Install]\nWantedBy=graphical.target\n' $2/lib/systemd/system/gdm.service
			#rm -rf $2/etc/systemd/system/display-manager.service
			ln -sf /lib/systemd/system/gdm.service $2/etc/systemd/system/graphical.target.wants/gdm.service
			;;

		ls1043*|ls1046*)
			ln -sf /lib/systemd/system/fmc.service $2/etc/systemd/system/multi-user.target.wants/fmc.service
			;;
		ls*|lx*)
			;;
		*)
			echo " Error: $1 is not supported "
			exit 1
			;;
	esac

	sed -i 's/^SUBSYSTEM/#SUBSYSTEM/' $2/usr/lib/udev/rules.d/50-firmware.rules
	echo "$1" > $2/etc/hostname

    ### network config
    # disable rename network interface
    ln -s /dev/null $2/etc/udev/rules.d/80-net-setup-link.rules
    # disable systemd-networkd-wait-online to speed up the boot
    rm -f $2/etc/systemd/system/network-online.target.wants/systemd-networkd-wait-online.service
    # disable legacy networking service
    rm -f $2/etc/systemd/system/network-online.target.wants/networking.service
    rm -f $2/etc/systemd/system/multi-user.target.wants/networking.service

    # use systemd-networkd
    ln -sf /usr/lib/systemd/system/systemd-networkd.service $2/etc/systemd/system/dbus-org.freedesktop.network1.service
    ln -sf /usr/lib/systemd/system/systemd-networkd.service $2/etc/systemd/system/multi-user.target.wants/systemd-networkd.service
    ln -sf /usr/lib/systemd/system/systemd-networkd.socket $2/etc/systemd/system/sockets.target.wants/systemd-networkd.socket
    ln -sf /usr/lib/systemd/system/systemd-network-generator.service $2/etc/systemd/system/sysinit.target.wants/systemd-network-generator.service
	#ln -sf /usr/lib/systemd/system/systemd-networkd-wait-online.service $2/etc/systemd/system/network-online.target.wants/systemd-networkd-wait-online.service

    # for timesync
    sed -i '/^\[Time\]/a NTP=time1.google.com time2.google.com time3.google.com\nFallbackNTP=ntp.aliyun.com cn.ntp.org.cn' $2/etc/systemd/timesyncd.conf

    # continue to config the board at runtime
    ln -sf /usr/lib/systemd/system/platcfg.service $2/etc/systemd/system/multi-user.target.wants/platcfg.service
}
